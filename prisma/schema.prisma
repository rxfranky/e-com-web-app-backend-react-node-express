generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model cart {
  id       Int      @id @default(autoincrement())
  product  Int
  quantity Int      @default(1)
  consumer Int
  users    users    @relation(fields: [consumer], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products products @relation(fields: [product], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id       Int      @id @default(autoincrement())
  product  Int
  quantity Int
  order_id String   @db.VarChar(99)
  consumer Int
  users    users    @relation(fields: [consumer], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products products @relation(fields: [product], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model products {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(30)
  price     Decimal  @db.Decimal(10, 2)
  image_src String   @db.VarChar(200)
  creator   Int
  image_id  String   @db.VarChar(99)
  cart      cart[]
  orders    orders[]
  users     users    @relation(fields: [creator], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                   Int        @id @default(autoincrement())
  name                 String     @db.VarChar(55)
  email                String     @unique @db.VarChar(100)
  password             String     @db.VarChar(60)
  created_at           DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?  @default(now()) @db.Timestamptz(6)
  password_reset_token String?    @unique @db.VarChar(100)
  reset_token_exp      DateTime?  @db.Timestamptz(6)
  cart                 cart[]
  orders               orders[]
  products             products[]
}
